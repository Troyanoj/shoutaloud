# Backend Environment Variables Template
# Copy this file to .env and fill in the values

# API Server
PORT=8000
API_BASE_URL=http://localhost:8000

# Database
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/shoutaloud

# Blockchain Configuration
# Chain ID (31337 = Hardhat, 11155111 = Sepolia, 1 = Mainnet)
BLOCKCHAIN_CHAIN_ID=31337
BLOCKCHAIN_NETWORK_NAME=Hardhat Local
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545

# Smart Contract Address
# Update after deploying to testnet/mainnet
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# IPFS Configuration
IPFS_API_URL=https://ipfs.io/ipfs
IPFS_GATEWAY_URL=https://cloudflare-ipfs.com/ipfs

# JWT Secret
# IMPORTANT: Change this in production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Settings
# Frontend URL for CORS
CORS_ORIGIN=http://localhost:5173

# AI Service (optional)
# Get API keys from https://platform.openai.com/ or https://www.anthropic.com/
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=