# Environment Variables Template
# Copy this file to .env and fill in the values

# Backend API URL
# The base URL for the backend API server
VITE_API_URL=http://localhost:8000

# Blockchain RPC URL
# The RPC endpoint for blockchain node (Hardhat, Sepolia, Mainnet, etc.)
VITE_BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545

# Smart Contract Address
# The address of the deployed voting smart contract
VITE_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# IPFS API URL
# The gateway URL for IPFS file storage
VITE_IPFS_API_URL=https://ipfs.io/ipfs

# Infura Project ID (optional)
# Required for connecting to Ethereum mainnet or testnets
# Get your project ID at https://infura.io/
# VITE_WEB3_INFURA_ID=