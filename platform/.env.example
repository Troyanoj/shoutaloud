# ShoutAloud Docker Environment Variables
# Copy this file to .env and configure the values

# ==================== PostgreSQL ====================
POSTGRES_DB=shoutaloud
POSTGRES_USER=shoutaloud
POSTGRES_PASSWORD=shoutaloud_password_change_in_production
POSTGRES_PORT=5432

# ==================== Redis ====================
REDIS_PORT=6379

# ==================== IPFS ====================
IPFS_SWARM_PORT=4001
IPFS_API_PORT=5001
IPFS_GATEWAY_PORT=8080

# ==================== Backend ====================
BACKEND_PORT=8000

# ==================== Frontend ====================
FRONTEND_PORT=5173

# ==================== Hardhat Blockchain ====================
HARDHAT_RPC_PORT=8545
HARDHAT_WS_PORT=8546
# Optional: Fork from a real network (e.g., Sepolia testnet)
# ETHEREUM_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ==================== Nginx ====================
HTTP_PORT=80
HTTPS_PORT=443

# ==================== Security ====================
# IMPORTANT: Change this in production!
JWT_SECRET=shoutaloud-super-secret-jwt-key-change-in-production

# ==================== Blockchain ====================
# Smart contract address (deploy using Hardhat first)
CONTRACT_ADDRESS=
BLOCKCHAIN_CHAIN_ID=31337

# ==================== Optional: External Services ====================
# OpenAI API key (for AI analysis features)
# OPENAI_API_KEY=

# Optional: Ethereum mainnet/testnet RPC (for advanced features)
# ETHEREUM_RPC_URL=

# ==================== Development ====================
DEBUG=false
