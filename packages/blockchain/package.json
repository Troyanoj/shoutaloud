{
  "name": "shoutaloud-blockchain",
  "version": "2.0.0",
  "description": "ShoutAloud Smart Contracts - Hardhat development environment",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
